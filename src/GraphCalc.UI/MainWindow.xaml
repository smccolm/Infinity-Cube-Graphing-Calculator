<Window x:Class="GraphCalc.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:GraphCalc.UI"
        Title="GraphCalc TAN Cube" Height="900" Width="1500"
        WindowStartupLocation="CenterScreen">
    <DockPanel Background="White">
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="File">
                <MenuItem Header="Test Mode..." Click="TestModeMenu_Click" />
                <MenuItem Header="Level of Detail..." Click="LevelOfDetailMenu_Click" />
                <Separator />
                <MenuItem Header="Exit" Click="Exit_Click" />
            </MenuItem>
            <MenuItem Header="View">
                <MenuItem x:Name="MeshMenuItem" Header="✓ Mesh" Click="MeshMenu_Click" />
                <MenuItem x:Name="SurfaceMenuItem" Header="Surface" Click="SurfaceMenu_Click" />
                <MenuItem Header="Surface Quality">
                    <MenuItem x:Name="SurfaceQualityFastMenuItem" Header="Fast" Click="SurfaceQualityFastMenu_Click" />
                    <MenuItem x:Name="SurfaceQualitySmoothMenuItem" Header="✓ Smooth" Click="SurfaceQualitySmoothMenu_Click" />
                    <MenuItem x:Name="SurfaceQualityCinematicMenuItem" Header="Cinematic" Click="SurfaceQualityCinematicMenu_Click" />
                </MenuItem>
                <Separator />
                <MenuItem Header="Reset View" Click="ResetView_Click" />
                <Separator />
                <MenuItem Header="Show/Hide Gimbal" Click="ToggleGimbal_Click" />
            </MenuItem>
        </Menu>

        <Grid Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*" />
                <ColumnDefinition Width="1.65*" />
                <ColumnDefinition Width="2.75*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="Black" BorderThickness="3" Margin="0,0,4,0">
                <Grid>
                    <local:Graph3DView x:Name="TanCubeView" />
                    <Border x:Name="GimbalPanel" Width="142" Height="116" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0" Background="#FFE6E6E6">
                        <Grid>
                            <local:GimbalView x:Name="GimbalView" Margin="0" />
                            <Button x:Name="GimbalCloseButton" Content="X" Width="24" Height="24" HorizontalAlignment="Right" VerticalAlignment="Top" Click="GimbalCloseButton_Click" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="2,0,4,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" BorderBrush="Black" BorderThickness="3" Margin="0,0,0,4">
                    <local:ProjectionView x:Name="XYView" Plane="XY" />
                </Border>
                <Border Grid.Row="1" BorderBrush="Black" BorderThickness="3" Margin="0,2,0,4">
                    <local:ProjectionView x:Name="XZView" Plane="XZ" />
                </Border>
                <Border Grid.Row="2" BorderBrush="Black" BorderThickness="3" Margin="0,2,0,0">
                    <local:ProjectionView x:Name="YZView" Plane="YZ" />
                </Border>
            </Grid>

            <Border Grid.Column="2" BorderBrush="Black" BorderThickness="3" Margin="0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="8">
                        <TextBlock Text="Functions" FontWeight="Bold" FontSize="16" />
                        <TextBlock x:Name="StatusText" Text="" Visibility="Collapsed" />
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="FunctionStackPanel" Margin="8,0,8,8" />
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
